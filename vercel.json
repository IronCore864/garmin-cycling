{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "app.py"
        }
    ],
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "0 1 * * *"
        },
        {
            "path": "/api/cron",
            "schedule": "0 14 * * *"
        }
    ]
}
